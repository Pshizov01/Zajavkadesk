Функция ЗначенияПеречисления(ИмяПеречисления)
	
	Список = Новый Массив;
	МетаданныеПеречисления = Метаданные.Перечисления[ИмяПеречисления];
	Для КАждого Значение Из МетаданныеПеречисления.ЗначенияПеречисления Цикл
		Список.Добавить(Значение.Имя);
	КонецЦикла;
	Возврат Список;
	
КонецФункции

Функция КатегорииПолучитьКатегории(Запрос)
	
	Попытка
		
		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст = "ВЫБРАТЬ
		|	Категории.Код КАК Код,
		|	Категории.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Категории КАК Категории";
		
		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();
		Список = Новый Массив;
		
		Пока Выборка.Следующий() Цикл
			Элемент = Новый Структура;
			Элемент.Вставить("id", Выборка.Код);
			Элемент.Вставить("name", Выборка.Наименование);
			Список.Добавить(Элемент);
		КонецЦикла;		
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Список));
		Возврат Ответ;
		
	Исключение
		Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
	КонецПопытки;
		
КонецФункции

Функция ВСтрокуJSON(Данные)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция ОтветОшибки(КодHTTP, КодОшибки, Сообщение)
	Данные = Новый Структура;
	Данные.Вставить("error", КодОшибки);
	Данные.Вставить("message", Сообщение);
	
	Ответ = Новый HTTPСервисОтвет(КодHTTP);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
	Возврат Ответ;
		
КонецФункции

Функция ЗаявкиСоздатьЗаявку(Запрос)

	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Запрос.ПолучитьТелоКакСтроку("UTF-8"));
		Тело = ПрочитатьJSON(ЧтениеJSON);
		
		ТелеграмИД = Тело["telegram_id"];
		Описание = Тело["описание"];
		Категория = Тело["категория"];
		Приоритет = Тело["приоритет"];
		
		ЗапросИД = Новый Запрос;
		ЗапросИД.Текст = "ВЫБРАТЬ
		                 |	Пользователи.TelegramID КАК TelegramID,
		                 |	Пользователи.Имя КАК Имя,
		                 |	Пользователи.Ссылка КАК Ссылка
		                 |ИЗ
		                 |	Справочник.Пользователи КАК Пользователи
		                 |ГДЕ
		                 |	Пользователи.TelegramID = &TelegramID";
		
		ЗапросИД.УстановитьПараметр("TelegramID", ТелеграмИД);

	    Выборка = ЗапросИД.Выполнить().Выбрать();
		
		Если НЕ Выборка.Следующий()Тогда 
			Возврат ОтветОшибки(404, "not_Found", "Пользователь не найден");
		КонецЕсли;
		
		Заявитель = Выборка.Ссылка;
		
		ЗапросКатегории = Новый Запрос;
		ЗапросКатегории.Текст = "ВЫБРАТЬ
		                        |	Категории.Ссылка КАК Ссылка
		                        |ИЗ
		                        |	Справочник.Категории КАК Категории
		                        |ГДЕ
		                        |	Категории.Наименование = &Наименование";
		
		ЗапросКатегории.УстановитьПараметр("Наименование", Категория);
		
		ВыборкаКатегории = ЗапросКатегории.Выполнить().Выбрать();
		
		Если НЕ ВыборкаКатегории.Следующий() Тогда
			Возврат ОтветОшибки(404, "not_found", "Категория не найдена");
		КонецЕсли;
		
		КатегорияСсылка = ВыборкаКатегории.Ссылка; 
		
		ПриоритетЗначение = Перечисления.ПриоритетыЗаявок[Приоритет];
		
		Если Приоритет = "Критический" Тогда
		    ЧасовНаРешение = 4;
		ИначеЕсли Приоритет = "Высокий" Тогда
		    ЧасовНаРешение = 8;
		ИначеЕсли Приоритет = "Средний" Тогда
		    ЧасовНаРешение = 24;
		Иначе
		    ЧасовНаРешение = 72;
		КонецЕсли;

		СрокРешения = ТекущаяДата() + (ЧасовНаРешение * 3600);
		
		НоваяЗаявка = Документы.Заявка.СоздатьДокумент();
		НоваяЗаявка.Заявитель    = Заявитель;
		НоваяЗаявка.Категория    = КатегорияСсылка;
		НоваяЗаявка.Приоритет    = ПриоритетЗначение;
		НоваяЗаявка.ТекущийСтатус = Перечисления.СтатусыЗаявок.Новая;
		НоваяЗаявка.Описание      = Описание;
		НоваяЗаявка.СрокРешения   = СрокРешения;
		НоваяЗаявка.Дата          = ТекущаяДата();

		НоваяЗаявка.Записать();

		// Формируем ответ
		Данные = Новый Структура;
		Данные.Вставить("id", Строка(НоваяЗаявка.Ссылка.УникальныйИдентификатор()));
		Данные.Вставить("номер",         НоваяЗаявка.Номер);
		Данные.Вставить("статус",        Строка(НоваяЗаявка.ТекущийСтатус));
		Данные.Вставить("срок_решения",  НоваяЗаявка.СрокРешения);

		Ответ = Новый HTTPСервисОтвет(201);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
		Возврат Ответ;
		
		
	Исключение
    	Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
	КонецПопытки;
	
	
КонецФункции

Функция ЗаявкаПолучитьЗаявку(Запрос)

	Попытка
		Ид = Запрос.ПараметрыURL["id"];
		
		УИД = Новый УникальныйИдентификатор(ИД);
		СсылкаНаЗаявку = Документы.Заявка.ПолучитьСсылку(УИД);
		СсылкаНаДокумент = СсылкаНаЗаявку.ПолучитьОбъект();
		
		Если СсылкаНаДокумент = Неопределено Тогда
			Возврат ОтветОшибки(404, "not_found", "Заявка не найдена");
		КонецЕсли;
		
		Данные = Новый Структура;
		Данные.Вставить("id", Строка(СсылкаНаДокумент.Ссылка.УникальныйИдентификатор()));
		Данные.Вставить("номер", СсылкаНаДокумент.Номер);
		Данные.Вставить("статус", Строка(СсылкаНаДокумент.ТекущийСтатус));
		Данные.Вставить("приоритет", Строка(СсылкаНаДокумент.Приоритет));
		Данные.Вставить("заявитель", СсылкаНаДокумент.Заявитель.Имя);
		Данные.Вставить("исполнитель", СсылкаНаДокумент.Исполнитель.Имя);
		Данные.Вставить("срок_решения", Строка(СсылкаНаДокумент.СрокРешения));
		Данные.Вставить("история", Новый Массив);
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
		Возврат Ответ;
		
		
	Исключение
		Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
	КонецПопытки;
		
КонецФункции

Функция ЗаявкиПользователяПолучитьЗаявки(Запрос)
	
	Попытка
		// Шаг 1 — читаем query-параметры из URL
		ТелеграмИДЗаявителя = Запрос.ПараметрыЗапроса.Получить("user");
		СтатусФильтр        = Запрос.ПараметрыЗапроса.Получить("status");

		// Шаг 2 — находим заявителя по telegram_id
		ЗапросПользователя = Новый Запрос;
		ЗапросПользователя.Текст = "ВЫБРАТЬ
		|	Пользователи.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.TelegramID = &TelegramID";
		ЗапросПользователя.УстановитьПараметр("TelegramID", ТелеграмИДЗаявителя);

		ВыборкаПользователя = ЗапросПользователя.Выполнить().Выбрать();

		Если НЕ ВыборкаПользователя.Следующий() Тогда
			Возврат ОтветОшибки(404, "not_found", "Пользователь не найден");
		КонецЕсли;

		Заявитель = ВыборкаПользователя.Ссылка;

		// Шаг 3 — собираем текст запроса к заявкам, базовая часть
		ТекстЗапроса = "ВЫБРАТЬ
		|	Заявка.Ссылка КАК Ссылка,
		|	Заявка.Номер КАК Номер,
		|	Заявка.Тема КАК Тема,
		|	Заявка.ТекущийСтатус КАК ТекущийСтатус,
		|	Заявка.Приоритет КАК Приоритет,
		|	Заявка.СрокРешения КАК СрокРешения
		|ИЗ
		|	Документ.Заявка КАК Заявка
		|ГДЕ
		|	Заявка.Заявитель = &Заявитель";

		// Шаг 4 — если статус передан, добавляем условие к тексту
		Если СтатусФильтр <> Неопределено Тогда
			ТекстЗапроса = ТекстЗапроса + "
			|	И Заявка.ТекущийСтатус = &Статус";
		КонецЕсли;

		ЗапросЗаявок = Новый Запрос;
		ЗапросЗаявок.Текст = ТекстЗапроса;
		ЗапросЗаявок.УстановитьПараметр("Заявитель", Заявитель);

		Если СтатусФильтр <> Неопределено Тогда
			ЗапросЗаявок.УстановитьПараметр("Статус", Перечисления.СтатусыЗаявок[СтатусФильтр]);
		КонецЕсли;

		// Шаг 5 — выполняем и собираем массив
		ВыборкаЗаявок = ЗапросЗаявок.Выполнить().Выбрать();
		Список = Новый Массив;

		Пока ВыборкаЗаявок.Следующий() Цикл
			Элемент = Новый Структура;
			Элемент.Вставить("id",            Строка(ВыборкаЗаявок.Ссылка.УникальныйИдентификатор()));
			Элемент.Вставить("номер",         ВыборкаЗаявок.Номер);
			Элемент.Вставить("тема",          ВыборкаЗаявок.Тема);
			Элемент.Вставить("статус",        Строка(ВыборкаЗаявок.ТекущийСтатус));
			Элемент.Вставить("приоритет",     Строка(ВыборкаЗаявок.Приоритет));
			Элемент.Вставить("срок_решения",  Строка(ВыборкаЗаявок.СрокРешения));
			Список.Добавить(Элемент);
		КонецЦикла;

		// Шаг 6 — возвращаем ответ
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Список));
		Возврат Ответ;

	Исключение
		Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
	КонецПопытки;
			
		
КонецФункции

