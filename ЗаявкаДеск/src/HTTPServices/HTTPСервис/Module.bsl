Функция ЗаявкаСтатус(Запрос)
	Попытка
		
		ИД = Запрос.ПараметрыURL["id"];
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Запрос.ПолучитьТелоКакСтроку("UTF-8"));
		Тело = ПрочитатьJSON(ЧтениеJSON);
		
		НовыйСтатус = Тело["новый_статус"];
		Комментарий = Тело["комментарий"];
		
		УИД = Новый УникальныйИдентификатор(ИД);
		Ссылка = Документы.Заявка.ПолучитьСсылку(УИД);
		СсылкаНаЗаявку = Ссылка.ПолучитьОбъект();
		
		Если СсылкаНаЗаявку = Неопределено Тогда
			Возврат ОтветОшибки(404, "not_found", "Заявка не найдена");
		КонецЕсли;
		
		НачатьТранзакцию();
		
		СсылкаНаЗаявку.Заблокировать();
		
		ТекущийСтатус = Строка(СсылкаНаЗаявку.ТекущийСтатус);
		
		СтатусЗаявки = Перечисления.СтатусыЗаявок[НовыйСтатус];
		
		Если ТекущийСтатус = "Новая" Тогда
			Если НЕ НовыйСтатус = "ВРаботе" И НЕ НовыйСтатус = "Отклонена" Тогда
				ОтменитьТранзакцию();
				Возврат ОтветОшибки(409,"invalid_transition","Переход запрещен")
			КонецЕсли;
			
		ИначеЕсли ТекущийСтатус = "ВРаботе" Тогда
			Если НЕ НовыйСтатус = "Решена" И Не НовыйСтатус = "Отклонена" Тогда
				ОтменитьТранзакцию();
				Возврат ОтветОшибки(409,"invalid_transition","Переход запрещен");
			КонецЕсли;
			
		ИначеЕсли ТекущийСтатус = "Решена" Тогда
			Если Не НовыйСтатус = "Закрыта" И не НовыйСтатус = "ВРаботе" Тогда
				ОтменитьТранзакцию();
				Возврат ОтветОшибки(409,"invalid_transition","Переход запрещен")
			КонецЕсли;
			
		ИначеЕсли ТекущийСтатус = "Закрыта" Или ТекущийСтатус = "Отклонена" Тогда
			ОтменитьТранзакцию();
			Возврат ОтветОшибки(409,"invalid_transition","Переход запрещен")
		КонецЕсли;
		
		СсылкаНаЗаявку.ТекущийСтатус = СтатусЗаявки;
		СсылкаНаЗаявку.Записать();
		
		ЗафиксироватьТранзакцию();
		
		Данные = Новый Структура;
		Данные.Вставить("id",     Строка(СсылкаНаЗаявку.Ссылка.УникальныйИдентификатор()));
		Данные.Вставить("номер",  СсылкаНаЗаявку.Номер);
		Данные.Вставить("статус", Строка(СсылкаНаЗаявку.ТекущийСтатус));;
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
		Возврат Ответ;

	Исключение
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
		Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

