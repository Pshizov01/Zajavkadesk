
Функция ПользовательПолучитьПользователя(Запрос)
	
	Попытка
        ИД = Запрос.ПараметрыURL["telegram_id"];

        ЗапросБД = Новый Запрос;
        ЗапросБД.Текст = "ВЫБРАТЬ
        |   Пользователи.TelegramID КАК TelegramID,
        |   Пользователи.Имя КАК Имя,
        |   Пользователи.Роль КАК Роль,
        |   Пользователи.Активен КАК Активен
        |ИЗ
        |   Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |   Пользователи.TelegramID = &TelegramID";

        ЗапросБД.УстановитьПараметр("TelegramID", ИД); // ← обязательно!

        Выборка = ЗапросБД.Выполнить().Выбрать();

        Если НЕ Выборка.Следующий() Тогда // ← один пользователь или никого
            Возврат ОтветОшибки(404, "not_found", "Пользователь не найден");
        КонецЕсли;

        Данные = Новый Структура;
        Данные.Вставить("telegram_id", Выборка.TelegramID);
        Данные.Вставить("name", Выборка.Имя);
        Данные.Вставить("role", Строка(Выборка.Роль)); // ← Строка() обязательно
        Данные.Вставить("active", Выборка.Активен);

        Ответ = Новый HTTPСервисОтвет(200);
        Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
        Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные)); // ← Данные, не Список
        Возврат Ответ;

    Исключение
        Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
    КонецПопытки;
		
КонецФункции

Функция РегистрацияПользователейЗарегистрироватьПользователя(Запрос)
	
	Попытка
        // 1. Читаем тело
        ЧтениеJSON = Новый ЧтениеJSON;
        ЧтениеJSON.УстановитьСтроку(Запрос.ПолучитьТелоКакСтроку("UTF-8"));
        Тело = ПрочитатьJSON(ЧтениеJSON);

        // 2. Достаём поля — ключи должны совпадать с тем что шлёт Python
        ТелеграмИД = Тело["telegram_id"];
        Имя        = Тело["имя"];

        // 3. Ищем пользователя
        ЗапросБД = Новый Запрос;
        ЗапросБД.Текст = "ВЫБРАТЬ
        |   Пользователи.TelegramID КАК TelegramID,
        |   Пользователи.Имя КАК Имя,
        |   Пользователи.Роль КАК Роль,
        |   Пользователи.Активен КАК Активен
        |ИЗ
        |   Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |   Пользователи.TelegramID = &TelegramID";
        ЗапросБД.УстановитьПараметр("TelegramID", ТелеграмИД);

        Выборка = ЗапросБД.Выполнить().Выбрать();

        Если Выборка.Следующий() Тогда
            // 4. Нашли → возвращаем 200
            Данные = Новый Структура;
            Данные.Вставить("telegram_id", Выборка.TelegramID);
            Данные.Вставить("name",        Выборка.Имя);
            Данные.Вставить("role",        Строка(Выборка.Роль));
            Данные.Вставить("active",      Выборка.Активен);

            Ответ = Новый HTTPСервисОтвет(200);
            Ответ.Заголовки.Вставить("Content-Type", "application/json, charset=utf-8");
            Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
            Возврат Ответ;

        Иначе
            // 5. Не нашли → создаём нового
            НовыйПользователь = Справочники.Пользователи.СоздатьЭлемент();
            НовыйПользователь.TelegramID = ТелеграмИД;
            НовыйПользователь.Имя        = Имя;
            НовыйПользователь.Роль       = Перечисления.РолиПользователя.Заявитель;
            НовыйПользователь.Активен    = Истина;
            НовыйПользователь.Записать();

            Данные = Новый Структура;
            Данные.Вставить("telegram_id", НовыйПользователь.TelegramID);
            Данные.Вставить("name",        НовыйПользователь.Имя);
            Данные.Вставить("role",        Строка(НовыйПользователь.Роль));
            Данные.Вставить("active",      НовыйПользователь.Активен);

            Ответ = Новый HTTPСервисОтвет(201);
            Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
            Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
            Возврат Ответ;

        КонецЕсли;

    Исключение
        Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
    КонецПопытки;
		
	
КонецФункции

