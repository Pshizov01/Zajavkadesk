Функция ЗначенияПеречисления(ИмяПеречисления)
	
	Список = Новый Массив;
	МетаданныеПеречисления = Метаданные.Перечисления[ИмяПеречисления];
	Для КАждого Значение Из МетаданныеПеречисления.ЗначенияПеречисления Цикл
		Список.Добавить(Значение.Имя);
	КонецЦикла;
	Возврат Список;
	
КонецФункции

Функция КатегорииПолучитьКатегории(Запрос)
	
	Попытка
		
		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст = "ВЫБРАТЬ
		|	Категории.Код КАК Код,
		|	Категории.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Категории КАК Категории";
		
		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();
		Список = Новый Массив;
		
		Пока Выборка.Следующий() Цикл
			Элемент = Новый Структура;
			Элемент.Вставить("id", Выборка.Код);
			Элемент.Вставить("name", Выборка.Наименование);
			Список.Добавить(Элемент);
		КонецЦикла;		
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Список));
		Возврат Ответ;
		
	Исключение
		Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
	КонецПопытки;
		
КонецФункции

Функция ВСтрокуJSON(Данные)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция ОтветОшибки(КодHTTP, КодОшибки, Сообщение)
	Данные = Новый Структура;
	Данные.Вставить("error", КодОшибки);
	Данные.Вставить("message", Сообщение);
	
	Ответ = Новый HTTPСервисОтвет(КодHTTP);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
	Возврат Ответ;
		
КонецФункции
