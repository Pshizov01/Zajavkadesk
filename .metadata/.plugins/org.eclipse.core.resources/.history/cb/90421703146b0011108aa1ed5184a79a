
Функция ПользовательПолучитьПользователя(Запрос)
	
	Попытка
        ИД = Запрос.ПараметрыURL["telegram_id"];

        ЗапросБД = Новый Запрос;
        ЗапросБД.Текст = "ВЫБРАТЬ
        |   Пользователи.TelegramID КАК TelegramID,
        |   Пользователи.Имя КАК Имя,
        |   Пользователи.Роль КАК Роль,
        |   Пользователи.Активен КАК Активен
        |ИЗ
        |   Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |   Пользователи.TelegramID = &TelegramID";

        ЗапросБД.УстановитьПараметр("TelegramID", ИД); // ← обязательно!

        Выборка = ЗапросБД.Выполнить().Выбрать();

        Если НЕ Выборка.Следующий() Тогда // ← один пользователь или никого
            Возврат ОтветОшибки(404, "not_found", "Пользователь не найден");
        КонецЕсли;

        Данные = Новый Структура;
        Данные.Вставить("telegram_id", Выборка.TelegramID);
        Данные.Вставить("name", Выборка.Имя);
        Данные.Вставить("role", Строка(Выборка.Роль)); // ← Строка() обязательно
        Данные.Вставить("active", Выборка.Активен);

        Ответ = Новый HTTPСервисОтвет(200);
        Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
        Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные)); // ← Данные, не Список
        Возврат Ответ;

    Исключение
        Возврат ОтветОшибки(500, "error", ОписаниеОшибки());
    КонецПопытки;
		
КонецФункции

