
Функция КатегорииПолучитьКатегории(Запрос)
	
	Попытка
		ИД = Запрос.ПараметрыURL["id"];
		Категория = Справочники.Категории.НайтиПоКоду(ИД);
		Если Категория.Пустая() Тогда
			Возврат ОтветОшикби(404, "not_found", "Категория не найдена");
		КонецЕсли;
		
		Данные = Новый Структура;
		Данные.Вставить("id", Категория.Код);
		Данные.Вставить("name", Категория.Наименование);
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
		Возврат Ответ;
		
	Исключение
		Возврат ОтветОшибки()
	
КонецФункции

Функция ВСтрокуJSON(Данные)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция ОтветОшибки(КодHTTP, КодОшибки, Сообщение)
	Данные = Новый Структура;
	Данные.Вставить("error", КодОшибки);
	Данные.Вставить("message", Сообщение);
	
	Ответ = Новый HTTPСервисОтвет(КодHTTP);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
	Возврат Ответ;
		
КонецФункции
